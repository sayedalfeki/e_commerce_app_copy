#!/usr/bin/env bash

# Flutter/Dart Pre-commit Hook
# Runs the same lint checks as the GitHub Actions workflow

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Configuration
FLUTTER_VERSION="3.38.5"
CHANNEL="stable"
MAX_DART_FILE_SIZE=100 # KB
CHECK_TESTS=true

# Function to print colored messages
print_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

print_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Function to check Flutter installation
check_flutter() {
    print_info "Checking Flutter installation..."
    
    if ! command -v flutter &> /dev/null; then
        print_error "Flutter is not installed or not in PATH"
        print_info "Please install Flutter $FLUTTER_VERSION from: https://flutter.dev/docs/get-started/install"
        exit 1
    fi
    
    local current_version=$(flutter --version | grep -oP 'Flutter \K[\d.]+' | head -1)
    local current_channel=$(flutter channel | grep '*' | awk '{print $2}')
    
    print_info "Current Flutter version: $current_version ($current_channel)"
    print_info "Required version: $FLUTTER_VERSION ($CHANNEL)"
    
    if [ "$current_version" != "$FLUTTER_VERSION" ]; then
        print_warning "Flutter version mismatch. Consider using: flutter version $FLUTTER_VERSION"
    fi
    
    if [ "$current_channel" != "$CHANNEL" ]; then
        print_warning "Flutter channel mismatch. Consider switching: flutter channel $CHANNEL"
    fi
}

# Function to check staged files
check_staged_files() {
    print_info "Checking staged Dart files..."
    
    # Get list of staged Dart files
    local staged_files=$(git diff --cached --name-only --diff-filter=ACM | grep '\.dart$')
    
    if [ -z "$staged_files" ]; then
        print_info "No Dart files staged for commit. Skipping Dart-specific checks."
        return 0
    fi
    
    print_info "Staged Dart files:"
    echo "$staged_files" | while read file; do
        echo "  - $file"
    done
    
    # Export for use in other functions
    export STAGED_DART_FILES="$staged_files"
}

# Function to check dependencies
check_dependencies() {
    print_info "Checking dependencies..."
    
    if [ ! -f "pubspec.yaml" ]; then
        print_error "pubspec.yaml not found!"
        exit 1
    fi
    
    # Check if dependencies are installed
    if [ ! -d ".dart_tool" ] && [ ! -d ".packages" ]; then
        print_warning "Dependencies not installed. Running 'flutter pub get'..."
        flutter pub get
    else
        print_info "Running 'flutter pub upgrade --dry-run'..."
        flutter pub upgrade --dry-run || true
    fi
}

# Function to check code formatting
check_formatting() {
    print_info "Checking code formatting..."
    
    if [ -z "$STAGED_DART_FILES" ]; then
        print_info "No Dart files to format check"
        return 0
    fi
    
    # Check formatting for staged files only
    local formatting_issues=0
    
    # First, check if files are properly formatted
    print_info "Running 'flutter format --set-exit-if-changed --output=none' on staged files..."
    
    # Create a temporary file with list of staged files
    echo "$STAGED_DART_FILES" > /tmp/staged_files.txt
    
    # Check formatting
    if ! flutter format --set-exit-if-changed --output=none $(echo "$STAGED_DART_FILES" | tr '\n' ' ') 2>/dev/null; then
        print_error "Formatting issues found in staged files!"
        print_info "The following files need formatting:"
        
        # Check each file individually
        for file in $STAGED_DART_FILES; do
            if [ -f "$file" ]; then
                # Create backup and check if formatting changes it
                cp "$file" "/tmp/$file.backup"
                flutter format "$file" > /dev/null 2>&1
                if ! diff -q "/tmp/$file.backup" "$file" > /dev/null; then
                    print_warning "  - $file"
                    formatting_issues=$((formatting_issues + 1))
                fi
                # Restore original
                mv "/tmp/$file.backup" "$file"
            fi
        done
        
        if [ $formatting_issues -gt 0 ]; then
            print_info ""
            print_info "To fix formatting issues, run:"
            print_info "  flutter format $(echo "$STAGED_DART_FILES" | tr '\n' ' ')"
            print_info ""
            print_info "Or stage the fixes with:"
            print_info "  flutter format $(echo "$STAGED_DART_FILES" | tr '\n' ' ') && git add $(echo "$STAGED_DART_FILES" | tr '\n' ' ')"
            return 1
        fi
    fi
    
    print_success "All staged files are properly formatted!"
}

# Function to run static analysis
run_analysis() {
    print_info "Running static analysis..."
    
    if [ -z "$STAGED_DART_FILES" ]; then
        print_info "No Dart files to analyze"
        return 0
    fi
    
    # Run analyze on staged files
    print_info "Running 'flutter analyze' on staged files..."
    
    local analyze_output=$(flutter analyze $(echo "$STAGED_DART_FILES" | tr '\n' ' ') 2>&1)
    local analyze_status=$?
    
    if [ $analyze_status -ne 0 ]; then
        print_error "Analysis issues found:"
        echo "$analyze_output"
        
        # Count issues
        local error_count=$(echo "$analyze_output" | grep -c "error •" || true)
        local warning_count=$(echo "$analyze_output" | grep -c "warning •" || true)
        local info_count=$(echo "$analyze_output" | grep -c "info •" || true)
        
        print_info ""
        print_info "Analysis Summary:"
        print_info "  Errors: $error_count"
        print_info "  Warnings: $warning_count"
        print_info "  Info: $info_count"
        print_info ""
        
        if [ $error_count -gt 0 ]; then
            print_error "Please fix all errors before committing."
            return 1
        else
            print_warning "Warnings found. Consider fixing them before committing."
            # Allow commit with warnings, but show prompt
            read -p "Continue with commit despite warnings? (y/N): " -n 1 -r
            echo
            if [[ ! $REPLY =~ ^[Yy]$ ]]; then
                print_info "Commit cancelled by user."
                return 1
            fi
        fi
    else
        print_success "No analysis issues found!"
    fi
}

# Function to check for unused imports
check_unused_imports() {
    print_info "Checking for unused imports..."
    
    if [ ! -f "pubspec.yaml" ]; then
        return 0
    fi
    
    # Check if unused_files is available
    if ! dart pub global list | grep -q unused_files; then
        print_info "Installing unused_files package..."
        dart pub global activate unused_files 2>/dev/null || true
    fi
    
    # Check staged files for unused imports
    if [ -n "$STAGED_DART_FILES" ]; then
        for file in $STAGED_DART_FILES; do
            if [ -f "$file" ]; then
                # Simple grep check for obviously unused imports
                local has_unused=$(grep -n "^import.*;$" "$file" | while read line; do
                    local import_line=$(echo "$line" | cut -d: -f1)
                    local import_name=$(echo "$line" | sed -n "s/.*import ['\"]\([^'\"]*\)['\"].*/\1/p")
                    if [ -n "$import_name" ]; then
                        # Check if import is used in file
                        if ! grep -q "$import_name" <(sed "1,${import_line}d" "$file"); then
                            echo "  - Line $import_line: $import_name"
                        fi
                    fi
                done)
                
                if [ -n "$has_unused" ]; then
                    print_warning "Possible unused imports in $file:"
                    echo "$has_unused"
                fi
            fi
        done
    fi
}

# Function to check file sizes
check_file_sizes() {
    print_info "Checking Dart file sizes..."
    
    if [ -n "$STAGED_DART_FILES" ]; then
        local large_files=()
        
        for file in $STAGED_DART_FILES; do
            if [ -f "$file" ]; then
                local size_kb=$(( $(wc -c < "$file") / 1024 ))
                local line_count=$(wc -l < "$file")
                
                if [ $size_kb -gt $MAX_DART_FILE_SIZE ]; then
                    large_files+=("$file ($size_kb KB, $line_count lines)")
                fi
            fi
        done
        
        if [ ${#large_files[@]} -gt 0 ]; then
            print_warning "Large Dart files detected (over ${MAX_DART_FILE_SIZE}KB):"
            for file_info in "${large_files[@]}"; do
                echo "  - $file_info"
            done
            print_info "Consider splitting large files for better maintainability."
        fi
    fi
}

# Function to run tests on changed files
run_tests() {
    if [ "$CHECK_TESTS" != "true" ]; then
        return 0
    fi
    
    print_info "Checking for related tests..."
    
    if [ ! -d "test" ]; then
        print_info "No test directory found"
        return 0
    fi
    
    if [ -n "$STAGED_DART_FILES" ]; then
        local test_files_to_run=()
        
        # Find test files related to changed source files
        for file in $STAGED_DART_FILES; do
            # Convert lib/file.dart to test/file_test.dart
            local test_file=$(echo "$file" | sed 's|^lib/|test/|' | sed 's/\.dart$/_test.dart/')
            if [ -f "$test_file" ]; then
                test_files_to_run+=("$test_file")
            fi
            
            # Also check for widget tests
            local widget_test_file=$(echo "$file" | sed 's|^lib/|test/widgets/|' | sed 's/\.dart$/_test.dart/')
            if [ -f "$widget_test_file" ]; then
                test_files_to_run+=("$widget_test_file")
            fi
        done
        
        # Run unique test files
        test_files_to_run=($(echo "${test_files_to_run[@]}" | tr ' ' '\n' | sort -u | tr '\n' ' '))
        
        if [ ${#test_files_to_run[@]} -gt 0 ]; then
            print_info "Running related tests:"
            for test_file in "${test_files_to_run[@]}"; do
                echo "  - $test_file"
            done
            
            if flutter test "${test_files_to_run[@]}" --no-pub 2>/dev/null; then
                print_success "All tests passed!"
            else
                print_error "Some tests failed!"
                print_info "Please fix failing tests before committing."
                return 1
            fi
        else
            print_info "No related test files found for staged changes"
        fi
    fi
}

# Function to check analysis_options.yaml
check_analysis_options() {
    print_info "Checking analysis_options.yaml..."
    
    if [ ! -f "analysis_options.yaml" ] && [ ! -f ".analysis_options" ]; then
        print_error "analysis_options.yaml not found!"
        print_info "Please create an analysis_options.yaml file for consistent linting."
        print_info "You can start with:"
        print_info "  include: package:flutter_lints/flutter.yaml"
        return 1
    else
        print_success "analysis_options.yaml found"
    fi
}

# Main execution
main() {
    echo ""
    echo "========================================="
    echo "    Flutter/Dart Pre-commit Hook"
    echo "========================================="
    echo ""
    
    # Store current directory
    local original_dir=$(pwd)
    
    # Move to git root
    cd "$(git rev-parse --show-toplevel)"
    
    # Run checks
    local failed_checks=0
    
    # Check Flutter installation
    if ! check_flutter; then
        failed_checks=$((failed_checks + 1))
    fi
    
    # Check staged files
    check_staged_files
    
    # Check dependencies
    if ! check_dependencies; then
        failed_checks=$((failed_checks + 1))
    fi
    
    # Check analysis_options
    if ! check_analysis_options; then
        failed_checks=$((failed_checks + 1))
    fi
    
    # Run formatting check
    if ! check_formatting; then
        failed_checks=$((failed_checks + 1))
    fi
    
    # Run static analysis
    if ! run_analysis; then
        failed_checks=$((failed_checks + 1))
    fi
    
    # Check unused imports
    check_unused_imports
    
    # Check file sizes
    check_file_sizes
    
    # Run tests (optional)
    if ! run_tests; then
        failed_checks=$((failed_checks + 1))
    fi
    
    # Return to original directory
    cd "$original_dir"
    
    # Summary
    echo ""
    echo "========================================="
    echo "              Summary"
    echo "========================================="
    
    if [ $failed_checks -eq 0 ]; then
        print_success "All pre-commit checks passed!"
        echo ""
        echo "You can now commit your changes."
        exit 0
    else
        print_error "$failed_checks check(s) failed!"
        echo ""
        print_info "Please fix the issues above before committing."
        print_info "You can bypass this hook with: git commit --no-verify"
        echo ""
        exit 1
    fi
}

# Run main function
main "$@"